    "@tetherto/wdk-wallet-evm-erc-4337": "1.0.0-beta.5",
    "@tetherto/wdk-wallet-solana": "1.0.0-beta.5",
    "@tetherto/wdk-wallet-btc": "1.0.0-beta.6",
    "@tetherto/wdk-protocol-lending-aave-evm": "1.0.0-beta.3",
    "@tetherto/wdk-protocol-swap-velora-evm": "1.0.0-beta.4",
    "@tetherto/wdk-protocol-bridge-usdt0-evm": "1.0.0-beta.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ws": "^8.18.0",
    "zod": "^3.24.2",
    "winston": "^3.17.0",
    "ethers": "^6.13.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
